PORT=3000

# Elige una palabra o frase secreta y usa la misma en Meta al configurar el webhook.
VERIFY_TOKEN=ori-feria-origen-2027

# Datos de WhatsApp Cloud API. Los encuentras en Meta for Developers.
WHATSAPP_TOKEN=pega_aqui_tu_token_de_acceso
PHONE_NUMBER_ID=pega_aqui_el_id_del_numero
GRAPH_API_VERSION=v25.0
WHATSAPP_BUSINESS_ACCOUNT_ID=pega_aqui_el_id_de_la_cuenta_whatsapp_business
META_APP_ID=pega_aqui_el_id_de_la_app_meta

# Para probar sin enviar mensajes reales por WhatsApp, dejalo en true.
DRY_RUN=true

# ChatGPT es opcional. Ori funciona con su cerebro local aunque esto quede apagado.
USE_OPENAI=false
OPENAI_API_KEY=pega_aqui_tu_openai_api_key
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT=20

# Groq es opcional. Ori conserva su cerebro local y Groq ayuda a redactar mas humano.
USE_GROQ=false
GROQ_API_KEY=pega_aqui_tu_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=18
