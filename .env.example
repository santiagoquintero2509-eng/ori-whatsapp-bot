PORT=3000

# Elige una palabra o frase secreta y usa la misma en Meta al configurar el webhook.
VERIFY_TOKEN=ori-feria-origen-2027

# Datos de WhatsApp Cloud API. Los encuentras en Meta for Developers.
WHATSAPP_TOKEN=pega_aqui_tu_token_de_acceso
PHONE_NUMBER_ID=pega_aqui_el_id_del_numero
GRAPH_API_VERSION=v25.0
WHATSAPP_BUSINESS_ACCOUNT_ID=pega_aqui_el_id_de_la_cuenta_whatsapp_business
META_APP_ID=pega_aqui_el_id_de_la_app_meta

# Para probar sin enviar mensajes reales por WhatsApp, dejalo en true.
DRY_RUN=true

# Numero(s) con permiso para consultar memoria interna y confirmar stands.
# Puedes separar varios con coma. El numero debe ir con indicativo, sin espacios.
ADMIN_PHONES=573004851602
ORI_USER_MEMORY_PATH=memoria_revisable/usuarios.json

# Google Sheet donde se guardan respuestas del formulario.
# La hoja debe estar compartida con permiso de lectura para quien tenga el enlace.
USE_FORM_SHEET=true
FORM_RESPONSES_SHEET_ID=1zfw1C4a0PxP1zZFJY4fD4C8x-5_ONDq1CPuwszVDXDo
FORM_RESPONSES_GID=0
# Tambien puedes pegar el enlace compartido normal de Google Sheets.
FORM_RESPONSES_CSV_URL=https://docs.google.com/spreadsheets/d/1zfw1C4a0PxP1zZFJY4fD4C8x-5_ONDq1CPuwszVDXDo/edit?usp=sharing
FORM_RESPONSES_CACHE_SECONDS=120
FORM_RESPONSES_TIMEOUT=8

# Preinscripcion conversacional.
# PREINSCRIPTION_WEBHOOK_URL es el enlace del Web App de Google Apps Script.
# PREINSCRIPTION_DRIVE_FOLDER_ID es la carpeta madre donde Ori creara subcarpetas por razon social.
PREINSCRIPTION_WEBHOOK_URL=
PREINSCRIPTION_WEBHOOK_SECRET=
PREINSCRIPTION_DRIVE_FOLDER_ID=1-R2LEdh_m8bregAIy-uTOXRJRNlNyVEm

# ChatGPT es opcional. Ori funciona con su cerebro local aunque esto quede apagado.
USE_OPENAI=false
OPENAI_API_KEY=pega_aqui_tu_openai_api_key
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT=20

# Groq es opcional. Ori conserva su cerebro local y Groq ayuda a redactar mas humano.
USE_GROQ=false
GROQ_API_KEY=pega_aqui_tu_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=18
